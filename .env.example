# Frontend (Vite)
VITE_API_URL=http://localhost:3001
# Public token only (starts with pk.) — get one at https://account.mapbox.com/access-tokens/
# Do not use secret tokens (sk.) here; they are bundled into the browser and cannot load map tiles.
VITE_MAPBOX_TOKEN=pk.your_public_token_here

# Backend — required for shared reviews (local dev + Render)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
CORS_ORIGIN=http://localhost:5173
PORT=3001

# Contact form email (backend) — uses Gmail App Password or any SMTP provider
# CONTACT_TO defaults to kiankamshad717@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=kiankamshad717@gmail.com
# SMTP_PASS=your_gmail_app_password
# CONTACT_FROM="Brown Housing Site <kiankamshad717@gmail.com>"
